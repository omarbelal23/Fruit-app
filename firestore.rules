rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user documents and subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Orders subcollection under user
      match /orders/{orderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Cart subcollection under user
      match /cart/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Coupons subcollection
      match /coupons/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Products are readable by all authenticated users
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email in [
        'admin@fruitapp.com',
        'manager@fruitapp.com'
      ];
    }
  }
}
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Reviews can be read by all, written by authenticated users
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Categories are readable by all
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in [
        'admin@fruitapp.com',
        'manager@fruitapp.com'
      ];
    }
  }
}